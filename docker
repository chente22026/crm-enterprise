  seed:
    image: node:20-alpine
    working_dir: /app
    volumes:
      - ./backend:/app:ro
    environment:
      DATABASE_URL: "postgresql://postgres:postgres@db:5432/crm"
    depends_on:
      db:
        condition: service_healthy
      backend:
        condition: service_started
    command: sh -c "apk add --no-cache bash && cd /app && npm ci --production --no-audit --no-fund && npx prisma generate && node prisma/seed.js"
    restart: "no"
